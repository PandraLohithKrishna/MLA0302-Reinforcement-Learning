import random
import math

prices = [10, 20, 30]
demand = [0.8, 0.5, 0.3]
n = 100

def simulate(method):
    count = [1, 1, 1]
    reward = [0, 0, 0]
    total = 0

    for t in range(1, n + 1):
        if method == "Epsilon":
            arm = random.randrange(3) if random.random() < 0.1 else reward.index(max(reward))
        elif method == "UCB":
            arm = max(range(3), key=lambda i: reward[i]/count[i] + math.sqrt(2*math.log(t+1)/count[i]))
        else:  
            arm = random.randrange(3)

        sale = random.random() < demand[arm]
        money = prices[arm] if sale else 0
        reward[arm] += money
        count[arm] += 1
        total += money

    print(method, "Revenue =", total)

simulate("Epsilon")
simulate("UCB")
simulate("Thompson")
